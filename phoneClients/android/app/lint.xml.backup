<?xml version="1.0" encoding="UTF-8"?>
<lint>
    <!-- Disable NewApi check for specific cases since we handle compatibility properly -->
    <issue id="NewApi" severity="ignore" />
    
    <!-- Suppress other lint warnings that are not critical for store deployment -->
    <issue id="UnusedResources" severity="ignore" />
    <issue id="HardcodedText" severity="ignore" />
    <issue id="TypographyDashes" severity="ignore" />
    <issue id="IconLauncherShape" severity="ignore" />
    <issue id="MonochromeLauncherIcon" severity="ignore" />
    <issue id="Autofill" severity="ignore" />
    <issue id="UseKtx" severity="ignore" />
    <issue id="LockedOrientationActivity" severity="ignore" />
    <issue id="DiscouragedApi" severity="ignore" />
    <issue id="RedundantLabel" severity="ignore" />
    <issue id="UnusedAttribute" severity="ignore" />
    <issue id="OldTargetApi" severity="ignore" />
    <issue id="AndroidGradlePluginVersion" severity="ignore" />
    <issue id="GradleDependency" severity="ignore" />
    <issue id="InlinedApi" severity="ignore" />
</lint>
